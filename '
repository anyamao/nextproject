"use client";

import { useState } from "react";
import { Check, X, Loader2, Pencil } from "lucide-react";

type ProfileField =
  | "username"
  | "first_name"
  | "last_name"
  | "status"
  | "about";

interface EditableFieldProps {
  label: string;
  field: ProfileField;
  value: string | null;
  placeholder: string;
  multiline?: boolean;
  helper?: string;
  onSave: (field: ProfileField, newValue: string) => Promise<void>;
}

export default function EditableField({
  label,
  field,
  value,
  placeholder,
  multiline = false,
  helper,
  onSave,
}: EditableFieldProps) {
  const [isEditing, setIsEditing] = useState(false);
  const [editValue, setEditValue] = useState("");
  const [saving, setSaving] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const startEdit = () => {
    setEditValue(value || "");
    setIsEditing(true);
    setError(null);
  };

  const cancelEdit = () => {
    setIsEditing(false);
    setEditValue("");
    setError(null);
  };

  const handleSave = async () => {
    setSaving(true);
    setError(null);

    try {
      await onSave(field, editValue);
      setIsEditing(false);
      setEditValue("");
    } catch (err) {
      const message =
        err instanceof Error ? err.message : "Не удалось сохранить";
      setError(message);
    } finally {
      setSaving(false);
    }
  };

  const displayValue = value || placeholder;

  return (
    <div className="flex flex-col w-full mb-6">
      <div className="flex items-center justify-between mb-2">
        <p className="text-gray-500 smaller-text">{label}:</p>
        {!isEditing && (
          <button
            onClick={startEdit}
            className="text-blue-500 hover:text-blue-600 text-sm font-medium flex items-center gap-1"
          >
            <Pencil size={14} /> Изменить
          </button>
        )}
      </div>

      {isEditing ? (
        // Edit Mode
        <div className="flex items-start gap-2">
          {multiline ? (
            <textarea
              value={editValue}
              onChange={(e) => setEditValue(e.target.value)}
              className="flex-1 px-4 py-2 border h-[40px] border-gray-300 rounded-xl focus:ring-2 focus:ring-purple-500 outline-none resize-none"
              placeholder={placeholder}
              rows={3}
              maxLength={200}
              autoFocus
            />
          ) : (
            <input
              type="text"
              value={editValue}
              onChange={(e) => setEditValue(e.target.value)}
              className="flex-1 px-4 py-2 border border-gray-300 h-[60px] rounded-xl focus:ring-2 focus:ring-purple-500 outline-none"
              placeholder={placeholder}
              maxLength={50}
              autoFocus
              onKeyDown={(e) => {
                if (e.key === "Enter") handleSave();
                if (e.key === "Escape") cancelEdit();
              }}
            />
          )}
          <div className="flex gap-1">
            <button
              onClick={handleSave}
              disabled={saving || editValue === value}
              className="bg-green-500 hover:bg-green-600 disabled:opacity-50 text-white rounded-lg p-2 transition"
              title="Сохранить"
            >
              {saving ? (
                <Loader2 className="animate-spin w-4 h-4" />
              ) : (
                <Check className="w-4 h-4" />
              )}
            </button>
            <button
              onClick={cancelEdit}
              disabled={saving}
              className="bg-gray-400 hover:bg-gray-500 text-white rounded-lg p-2 transition"
              title="Отмена"
            >
              <X className="w-4 h-4" />
            </button>
          </div>
        </div>
      ) : (
        // Display Mode
        <div className="bg-white border border-gray-200 h-[60px] rounded-xl p-4 min-h-[50px]">
          <p className={value ? "text-gray-800" : "text-gray-400 italic"}>
            {displayValue}
          </p>
        </div>
      )}

      {error && (
        <p className="text-sm text-red-600 mt-2 bg-red-50 px-3 py-2 rounded-lg">
          ⚠️ {error}
        </p>
      )}

      {helper && !isEditing && (
        <p className="text-xs text-gray-400 mt-1">{helper}</p>
      )}
    </div>
  );
}
