# backend/.env.production

# PostgreSQL (пример для Timeweb/Selectel/Yandex Cloud)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Секретный ключ (сгенерируй надёжный!)
SECRET_KEY=prod-super-secret-key-never-share-xyz789abc123

# Режим отладки (выключен в prod!)
DEBUG=False

# CORS (твои домены)
CORS_ORIGINS=["https://maoschool.ru","https://maoschool.ru"]
